# Environment variables config
PROJECT_NAME="VQA ViT-PubMedBERT API Production"
VERSION="1.0.0"

# Change this to 'cuda' if running on a GPU machine
DEVICE="cpu" 

# Thresholds
MAX_IMAGE_SIZE_MB=5
MAX_QUESTION_LENGTH=128

# File paths
MODEL_PATH="models/best_vit_pubmedbert_slake.pth"
CAPTIONING_MODEL_PATH="models/best_captioning_roco_v6_fulldata.pth"

# --- Database ---
DATABASE_URL="postgresql+asyncpg://vqa_user:vqa_pass@localhost:5432/vqa_db"

# --- JWT Auth ---
JWT_SECRET_KEY="your-super-secret-key-change-in-production-please"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis Cache ---
REDIS_URL="redis://localhost:6379/0"

# --- MinIO Object Storage ---
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="medical-images"
MINIO_USE_SSL=false

# --- LLM Provider Configuration ---
# Options: "gemini" or "openai_compatible"
LLM_PROVIDER="openai_compatible"
LLM_BASE_URL="http://localhost:11434/v1"
LLM_API_KEY=""
LLM_MODEL_NAME="llama3.1"
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120
LLM_SUPPORTS_TOOL_CALLING=true

# --- Admin Defaults ---
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_EMAIL="admin@vqa.com"
DEFAULT_ADMIN_PASSWORD="Admin@123"
DEFAULT_RESET_PASSWORD="ChangeMe@123"

# --- Chat Limits ---
MAX_MESSAGES_PER_SESSION=50
MAX_CONVERSATION_HISTORY=10